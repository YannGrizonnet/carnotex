% Cadre pleine largeur avec fond et titre extérieur
\newcommand{\Carno@Frame}[3]{%
  \par\medskip
  \noindent
  \if\relax\detokenize{#2}\relax
  \else
    {\small\bfseries\color{#1!70!black}#2}%
    \par\vspace{0.2ex}%
  \fi
  \noindent
  \colorbox{#1!30!white}{%
    \begin{minipage}[t]{\dimexpr\linewidth-2\fboxsep\relax}
      #3%
    \end{minipage}%
  }%
  \par\medskip
}

%=================================================
% Panneaux pédagogiques TikZ
% Structure :
%   icône | titre
%   trait | contenu
%=================================================

\newcommand{\Carno@Panel}[2]{%
  \par\medskip
  \noindent
  \begin{tikzpicture}[inner sep=0pt, outer sep=0pt]

    \coordinate (origin) at (0,0);

    % Titre aligné avec le texte courant
    \node[
      anchor=north west,
      text width=\linewidth
    ] (title) at (origin) {%
      {\color{\Carno@StyleColor{#1}}\textbf{\Carno@StyleTitle{#1}}}%
    };

    % Contenu aligné avec le texte courant
    \node[
      anchor=north west,
      text width=\linewidth
    ] (content) at ([yshift=-1.35em]origin) {%
      {\color{CarnoPanelText}#2}%
    };

    % Icône et trait en marge, sans influencer l'alignement
    \node[
      overlay,
      anchor=north west,
      text=\Carno@StyleColor{#1},
      text width=1.6em,
      align=center
    ] at ([xshift=-2.0em]origin) {%
      \Carno@StyleIcon{#1}%
    };

    \draw[
      overlay,
      color=\Carno@StyleColor{#1},
      line width=\CarnoPanelLineWidth
    ]
      ([xshift=-1.2em]content.north west)
      --
      ([xshift=-1.2em]content.south west);

  \end{tikzpicture}
  \par\medskip
}

\newcommand{\Carno@PanelWithTitle}[3]{%
  \par\medskip
  \noindent
  \begin{tikzpicture}[inner sep=0pt, outer sep=0pt]

    \coordinate (origin) at (0,0);

    % Titre personnalisé aligné avec le texte courant
    \node[
      anchor=north west,
      text width=\linewidth
    ] (title) at (origin) {%
      {\color{\Carno@StyleColor{#1}}\textbf{#2}}%
    };

    % Contenu aligné avec le texte courant
    \node[
      anchor=north west,
      text width=\linewidth
    ] (content) at ([yshift=-1.35em]origin) {%
      {\color{CarnoPanelText}#3}%
    };

    % Icône et trait en marge, sans influencer l'alignement
    \node[
      overlay,
      anchor=north west,
      text=\Carno@StyleColor{#1},
      text width=1.6em,
      align=center
    ] at ([xshift=-2.0em]origin) {%
      \Carno@StyleIcon{#1}%
    };

    \draw[
      overlay,
      color=\Carno@StyleColor{#1},
      line width=\CarnoPanelLineWidth
    ]
      ([xshift=-1.2em]content.north west)
      --
      ([xshift=-1.2em]content.south west);

  \end{tikzpicture}
  \par\medskip
}

% Marque de marge
\newcommand{\Carno@MarginMark}[2]{%
  \marginnote{%
    \makebox[1.2cm][l]{%
      \textcolor{#1}{%
        \fontsize{6}{7}\selectfont
        \sffamily
        #2%
      }%
    }%
  }[0pt]%
}

% TODO
\newcommand{\Carno@TodoMark}[2]{%
  {\color{\Carno@StyleColor{todo}}%
    \Carno@StyleIcon{todo}~#1%
    \if\relax\detokenize{#2}\relax
    \else
      \ -- #2%
    \fi
  }%
}

\newcommand{\Carno@TodoMargin}[1]{%
  \margemark{\Carno@StyleColor{todo}}{\Carno@StyleIcon{todo}~#1}%
}

\newcommand{\Carno@TimeMargin}[1]{%
  \Carno@MarginMark{\Carno@StyleColor{temps}}{\Carno@StyleIcon{temps}~#1'}%
}

\newcommand{\Carno@PointsMargin}[1]{%
  \marginnote{~
  
    \vspace{-1.1ex}% <-- à ajuster
    \raggedright
    \footnotesize
    \color{CarnoExercise!80!black}
    \textbf{#1 pts}%
  }%
}

