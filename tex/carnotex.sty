%=================================================
% Briques internes de mise en forme
%=================================================

\makeatletter

% Cadre pleine largeur avec fond et titre extérieur
\newcommand{\Carno@Frame}[3]{%
  \par\medskip
  \noindent
  \if\relax\detokenize{#2}\relax
  \else
    {\small\bfseries\color{#1!70!black}#2}%
    \par\vspace{0.2ex}%
  \fi
  \noindent
  \colorbox{#1!30!white}{%
    \begin{minipage}[t]{\dimexpr\linewidth-2\fboxsep\relax}
      #3%
    \end{minipage}%
  }%
  \par\medskip
}

%=================================================
% Commandes publiques de mise en forme
%=================================================

\makeatletter

% Cadres
\NewDocumentCommand{\cadre}{m O{} +m}{%
  \Carno@Frame{#1}{#2}{#3}%
}

% Panneaux
\newcommand{\CarnoPanel}[2]{%
  \Carno@Panel{#1}{#2}%
}

\newcommand{\CarnoPanelTitle}[3]{%
  \Carno@PanelWithTitle{#1}{#2}{#3}%
}

% Marges
\newcommand{\margemark}[2]{%
  \Carno@MarginMark{#1}{#2}%
}

\newcommand{\todomark}[2]{%
  \Carno@TodoMark{#1}{#2}%
}

\newcommand{\todomargin}[1]{%
  \Carno@TodoMargin{#1}%
}

\newcommand{\timemargin}[1]{%
  \Carno@TimeMargin{#1}%
}

\newcommand{\pointsmargin}[1]{%
  \Carno@PointsMargin{#1}%
}

\makeatother

%=================================================
% Colonnes
%=================================================

\NewDocumentCommand{\col}{O{0.48} O{0.48} +m +m}{%
  \begin{minipage}[t]{#1\linewidth}
    \vspace{0pt}%
    #3
  \end{minipage}
  \hfill
  \begin{minipage}[t]{#2\linewidth}
    \vspace{0pt}%
    #4
  \end{minipage}\medskip\\%
}

%=================================================
% Bordure extérieure droite
%=================================================

\newif\ifCarnoBordure
\CarnoBordurefalse

\newcommand{\CarnoBordureColor}{CarnoDef}
\newcommand{\CarnoBordureText}{}

\makeatletter

\newcommand{\Carno@DrawBordure}{%
  \ifCarnoBordure
    \begin{tikzpicture}[remember picture,overlay]
      \fill[\CarnoBordureColor]
        (current page.north east)
        rectangle
        ([xshift=-\CarnoBordureWidth]current page.south east);

      \node[
        rotate=-90,
        anchor=center,
        text=white,
        font=\scshape\Large\bfseries
      ] at ([xshift=-0.5\CarnoBordureWidth-\CarnoBordureSafe]current page.east)
        {\CarnoBordureText};
    \end{tikzpicture}%
  \fi
}

\AddToHook{shipout/background}{\Carno@DrawBordure}

\makeatother

\NewDocumentCommand{\bordure}{O{CarnoDef} m}{%
  \renewcommand{\CarnoBordureColor}{#1}%
  \renewcommand{\CarnoBordureText}{#2}%
  \CarnoBorduretrue
}

%=================================================
% Décorations
%=================================================

\NewDocumentCommand{\colorline}{s O{black} O{\linewidth} O{0.5pt}}{%
  \par\noindent
  \IfBooleanTF{#1}
    {{\color{#2}\centerline{\rule{#3}{#4}}}}
    {{\color{#2}\rule{#3}{#4}}}%
  \par
}

\newcommand{\decoline}{%
  \pgfmathsetmacro{\longueur}{0.0351*\linewidth}
  \begin{tikzpicture}
    \draw (0,0) -- (\longueur,0)
      node[midway,fill=white] {\textleaf};
  \end{tikzpicture}%
}

\NewDocumentCommand{\histo}{+m}{%
  \par\medskip
  \noindent
  \decoline

  #1

  \par\noindent
  \colorline
  \par\medskip
}

\newcommand{\carreaux}[2]{%
  \begin{tikzpicture}
    \foreach \i in {0.2,0.4,...,#1}{
      \draw[very thin,lightgray] (0,\i) -- (#2,\i);
    \draw[thick,gray] (0,0) grid (#2,#1);
    \draw[very thick,red] (2,0) -- (2,#1);
    }
  \end{tikzpicture}%
}

