\makeatletter

\newcommand{\siecle}{%
  \@ifstar{\Carno@siecleStar}{\Carno@siecleNoStar}%
}

\newcommand{\Carno@siecleNoStar}[2][\ieme]{%
  \textsc{\romannumeral #2}\textsuperscript{#1}~siècle%
}

\newcommand{\Carno@siecleStar}[2][\ieme]{%
