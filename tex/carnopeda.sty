%=================================================
% Bandeau d'exercice
%=================================================

\definecolor{CarnoExercise}{RGB}{120,70,170}

\newcounter{CarnoExercice}

\newcommand{\CarnoExoDifficulty}[1]{%
  \foreach \i in {1,...,5}{%
    \ifnum\i>#1
      {\color{CarnoExercise!25}\raisebox{0.1ex}{\large$\bullet$}}%
    \else
      {\color{CarnoExercise}\raisebox{0.1ex}{\large$\bullet$}}%
    \fi
    \kern0.1em
  }%
}

\NewDocumentCommand{\exobandeau}{O{} m m}{%
  \refstepcounter{CarnoExercice}%

  % Points éventuels dans la marge
  \if\relax\detokenize{#1}\relax
  \else
    \pointsmargin{#1}%
  \fi

  \par\medskip
  \noindent
  {\color{CarnoExercise!80!black}\large\bfseries\theCarnoExercice}%
  \hspace{0.8em}%
  {\color{CarnoExercise!80!black}\bfseries\textsc{#2}}%
  \hfill
  \CarnoExoDifficulty{#3}%
  \\[-1.6ex]
  {\color{CarnoExercise}\rule{\linewidth}{0.5pt}}%
  \par\smallskip
}

